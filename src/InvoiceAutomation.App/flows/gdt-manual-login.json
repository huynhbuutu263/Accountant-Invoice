{
  "name": "GDT — đăng nhập thủ công → tra cứu hóa đơn điện tử mua vào",
  "version": "1.0.0",
  "description": "Opens the GDT portal and pauses so you can log in manually. Click OK in the dialog when you are logged in and the search page is ready. The automation then fills in the date range, invoice kind, and runs the export loop.",
  "variables": {
    "gdtHomeUrl": "https://hoadondientu.gdt.gov.vn/",
    "gdtTraCuuUrl": "https://hoadondientu.gdt.gov.vn/tra-cuu/tra-cuu-hoa-don",
    "gdtPostTraCuuReadySelector": "button[type='submit']:has-text('Tìm kiếm')",
    "gdtTabMuaVaoSelector": ".ant-tabs-tab:has-text('mua vào')",
    "gdtKetQuaKiemTraCombobox": "#ttxly [role='combobox']",
    "gdtKetQuaKiemTraDropdownOption": ".ant-select-dropdown:not(.ant-select-dropdown-hidden) .ant-select-dropdown-menu-item:has-text('Đã cấp mã hóa đơn')",
    "gdtTuNgaySelector": "#tngay input.ant-calendar-picker-input",
    "gdtDenNgaySelector": "#dngay input.ant-calendar-picker-input",
    "gdtTimKiemButton": "button[type='submit']:has-text('Tìm kiếm')",
    "gdtResultRowSelector": ".ant-table-tbody tr",
    "gdtRowDownloadSelector": ".ant-table-tbody tr:nth-child({{rowIndex}}) a, .ant-table-tbody tr:nth-child({{rowIndex}}) button"
  },
  "steps": [
    {
      "name": "Mở trang chủ GDT",
      "action": "navigate",
      "value": "{{gdtHomeUrl}}",
      "waitUntil": "domcontentloaded",
      "timeoutMs": 120000,
      "retry": { "count": 3, "backoffMs": [ 2000, 5000, 10000 ] },
      "comment": "Navigates to the portal home page so you can log in. The browser window will be visible."
    },
    {
      "name": "Chờ bạn đăng nhập — nhấn OK để tiếp tục",
      "action": "pauseForUser",
      "value": "Please log in to the GDT portal in the browser window, then click OK here to continue the automation.",
      "comment": "The automation pauses here. Log in manually, then click OK."
    },
    {
      "name": "Vào URL tra cứu (đã có session)",
      "action": "navigate",
      "value": "{{gdtTraCuuUrl}}",
      "waitUntil": "domcontentloaded",
      "timeoutMs": 120000
    },
    {
      "name": "Chờ form tra cứu hiển thị",
      "action": "wait",
      "selector": "{{gdtPostTraCuuReadySelector}}",
      "timeoutMs": 120000,
      "comment": "The Tìm kiếm submit button confirms the search UI has rendered."
    },
    {
      "name": "Tab Hóa đơn điện tử mua vào",
      "action": "click",
      "selector": "{{gdtTabMuaVaoSelector}}",
      "timeoutMs": 30000,
      "comment": "Switch to the purchase-invoice tab. Set enabled: false if it is already selected by default."
    },
    {
      "name": "Mở combobox Kết quả kiểm tra",
      "action": "click",
      "selector": "{{gdtKetQuaKiemTraCombobox}}",
      "timeoutMs": 30000
    },
    {
      "name": "Chọn Đã cấp mã hóa đơn",
      "action": "click",
      "selector": "{{gdtKetQuaKiemTraDropdownOption}}",
      "timeoutMs": 30000
    },
    {
      "name": "Từ ngày",
      "action": "fill",
      "selector": "{{gdtTuNgaySelector}}",
      "value": "{{fromDateVi}}",
      "javaScriptFill": true,
      "clearFirst": false,
      "timeoutMs": 20000
    },
    {
      "name": "Đến ngày",
      "action": "fill",
      "selector": "{{gdtDenNgaySelector}}",
      "value": "{{toDateVi}}",
      "javaScriptFill": true,
      "clearFirst": false,
      "timeoutMs": 20000
    },
    {
      "name": "Tìm kiếm",
      "action": "click",
      "selector": "{{gdtTimKiemButton}}",
      "timeoutMs": 30000
    },
    {
      "name": "Chờ bảng kết quả",
      "action": "wait",
      "selector": "{{gdtResultRowSelector}}",
      "timeoutMs": 120000
    },
    {
      "name": "Lặp từng dòng — tải từng hóa đơn",
      "action": "loop",
      "loopKind": "rows",
      "rowSelector": "{{gdtResultRowSelector}}",
      "rowVariable": "rowIndex",
      "maxIterations": 500,
      "children": [
        {
          "name": "Tải file dòng {{rowIndex}}",
          "action": "download",
          "selector": "{{gdtRowDownloadSelector}}",
          "savePath": "{{downloadsRoot}}\\gdt\\{{jobId}}\\row_{{rowIndex}}.xml",
          "timeoutMs": 120000,
          "onError": "continue"
        }
      ]
    }
  ]
}
